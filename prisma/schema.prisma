generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  KARYAWAN
}

enum LeaveType {
  CUTI_TAHUNAN
  SAKIT
  PERNIKAHAN_KARYAWAN
  PERNIKAHAN_ANAK
  KHITAN_BAPTIS
  ISTRI_MELAHIRKAN
  KEMATIAN_KELUARGA
  KARYAWATI_MELAHIRKAN
  KARYAWATI_KEGUGURAN
  IZIN_LAINNYA
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditActionType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  QUOTA_CREATE
  QUOTA_ADJUST
  QUOTA_ROLLOVER
  LEAVE_SUBMIT
  LEAVE_APPROVE
  LEAVE_REJECT
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  SETTING_UPDATE
  HOLIDAY_CREATE
  HOLIDAY_DELETE
  SUBCOMPANY_CREATE
  SUBCOMPANY_DELETE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  username     String?  @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(KARYAWAN)
  nik          String?  @unique
  level        String?
  department   String?
  position     String?
  lokasiKerja  String?  @map("lokasi_kerja")
  namaAtasan   String?  @map("nama_atasan")
  subCompanyId String?  @map("sub_company_id")
  atasanId     String?  @map("atasan_id")
  joinDate     DateTime @map("join_date") @db.Date
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  leaveRequests        LeaveRequest[]   @relation("UserLeaveRequests")
  reviewedLeaveRequests LeaveRequest[]  @relation("ReviewerLeaveRequests")
  annualQuotas         AnnualLeaveQuota[] @relation("UserQuotas")
  createdQuotas        AnnualLeaveQuota[] @relation("CreatorQuotas")
  adjustments          LeaveAdjustment[] @relation("UserAdjustments")
  createdAdjustments   LeaveAdjustment[] @relation("AdminAdjustments")
  subCompany           SubCompany?      @relation(fields: [subCompanyId], references: [id], onDelete: SetNull)
  atasan               User?            @relation("UserAtasan", fields: [atasanId], references: [id], onDelete: SetNull)
  bawahan              User[]           @relation("UserAtasan")

  @@map("users")
}

model SubCompany {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users     User[]

  @@map("sub_companies")
}

model AnnualLeaveQuota {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  cycleStart  DateTime @map("cycle_start") @db.Date
  cycleEnd    DateTime @map("cycle_end") @db.Date
  totalDays   Int      @map("total_days")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User           @relation("UserQuotas", fields: [userId], references: [id], onDelete: Restrict)
  createdBy   User           @relation("CreatorQuotas", fields: [createdById], references: [id], onDelete: Restrict)
  segments    LeaveSegment[]
  adjustments LeaveAdjustment[]

  @@index([userId, cycleStart])
  @@map("annual_leave_quotas")
}

model LeaveRequest {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  reason         String
  attachmentUrl  String?       @map("attachment_url")
  status         RequestStatus @default(PENDING)
  reviewedById   String?       @map("reviewed_by")
  reviewedAt     DateTime?     @map("reviewed_at")
  rejectionNote  String?       @map("rejection_note")
  submittedById  String?       @map("submitted_by") // for admin submitting on behalf
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  user       User           @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Restrict)
  reviewedBy User?          @relation("ReviewerLeaveRequests", fields: [reviewedById], references: [id], onDelete: SetNull)
  segments   LeaveSegment[]

  @@index([userId, status])
  @@map("leave_requests")
}

model LeaveSegment {
  id             String            @id @default(uuid())
  leaveRequestId String            @map("leave_request_id")
  leaveType      LeaveType         @map("leave_type")
  startDate      DateTime          @map("start_date") @db.Date
  endDate        DateTime          @map("end_date") @db.Date
  totalDays      Decimal           @map("total_days") @db.Decimal(5, 1)
  annualQuotaId  String?           @map("annual_quota_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  leaveRequest   LeaveRequest      @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  annualQuota    AnnualLeaveQuota? @relation(fields: [annualQuotaId], references: [id], onDelete: SetNull)

  @@index([leaveRequestId])
  @@index([annualQuotaId])
  @@index([startDate, endDate])
  @@map("leave_segments")
}

model CompanySetting {
  id                 String   @id @default(uuid())
  defaultAnnualDays  Int      @default(12) @map("default_annual_days")
  companyName        String   @default("Perusahaan") @map("company_name")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

model Holiday {
  id            String   @id @default(uuid())
  date          DateTime @unique @db.Date
  description   String
  isCutiBersama Boolean  @default(false) @map("is_cuti_bersama")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("holidays")
}

model LeaveAdjustment {
  id          String   @id @default(uuid())
  quotaId     String   @map("quota_id")
  userId      String   @map("user_id")
  createdById String   @map("created_by")
  days        Decimal  @db.Decimal(5, 1)       // signed: +2.0 credit, -1.0 deduction
  reason      String
  effectiveOn DateTime @map("effective_on") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  quota     AnnualLeaveQuota @relation(fields: [quotaId], references: [id], onDelete: Restrict)
  user      User             @relation("UserAdjustments",  fields: [userId],      references: [id], onDelete: Restrict)
  createdBy User             @relation("AdminAdjustments", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([quotaId])
  @@index([userId])
  @@index([effectiveOn])
  @@map("leave_adjustments")
}

model AuditLog {
  id          String          @id @default(uuid())
  actionType  AuditActionType @map("action_type")
  description String
  actorId     String?         @map("actor_id")
  actorName   String?         @map("actor_name")
  targetId    String?         @map("target_id")
  targetName  String?         @map("target_name")
  beforeState Json?           @map("before_state")
  afterState  Json?           @map("after_state")
  ipAddress   String?         @map("ip_address")
  userAgent   String?         @map("user_agent")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([actionType])
  @@index([actorId])
  @@map("audit_logs")
}
